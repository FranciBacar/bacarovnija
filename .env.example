# --- Strežnik ---
PORT=3000
NODE_ENV=production

# --- Admin prijava (spremeni obvezno!) ---
ADMIN_USER=blaz
ADMIN_PASSWORD=izberi-mocno-geslo
SESSION_SECRET=nakljucni-dolg-niz-spremeni-me

# --- E-pošta (Gmail) ---
# GMAIL_APP_PASSWORD je 16-mestno "geslo za aplikacije" (NE navadno geslo).
# Ustvariš ga na: https://myaccount.google.com/apppasswords (potreben je vklopljen 2-faktorski vstop)
GMAIL_USER=bacarovnija@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
NOTIFY_EMAIL=bacarovnija@gmail.com

# --- Baza (kam se shranjujejo prijave) ---
# Lokalno pusti privzeto. Na gostovanju s trajnim diskom nastavi npr. /data/registrations.json
DB_PATH=./data/registrations.json
